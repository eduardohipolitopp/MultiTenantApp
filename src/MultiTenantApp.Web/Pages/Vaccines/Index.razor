@page "/vaccines"
@attribute [Authorize(Roles = "Admin, Vaccines")]
@using MultiTenantApp.Web.Models.DTOs
@using MultiTenantApp.Web.Interfaces
@inject IVaccineService VaccineService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Vaccine Management</MudText>

<MudButton Variant="Variant.Filled" 
           Color="Color.Primary" 
           StartIcon="@Icons.Material.Filled.Add"
           OnClick="OpenCreateDialog"
           Class="mb-4">
    Add New Vaccine
</MudButton>

<MudDataGrid T="VaccineListDto" 
             ServerData="LoadServerData" 
             @ref="dataGrid"
             Filterable="true"
             SortMode="SortMode.Single"
             Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Vaccines</MudText>
        <MudSpacer />
        <MudTextField T="string" ValueChanged="@(s=>OnSearch(s))" Placeholder="Search Vaccines..." Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Name" />
        <PropertyColumn Property="x => x.Manufacturer" Title="Manufacturer" />
        <PropertyColumn Property="x => x.Doses" Title="Doses" />
        <TemplateColumn Title="Actions" Sortable="false" Filterable="false">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                               Color="Color.Primary" 
                               Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context.Item.Id))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                               Color="Color.Error" 
                               Size="Size.Small"
                               OnClick="@(() => DeleteVaccine(context.Item.Id))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="VaccineListDto" />
    </PagerContent>
</MudDataGrid>

@code {
    private MudDataGrid<VaccineListDto> dataGrid;
    private string searchString = null;

    private void OnSearch(string text)
    {
        searchString = text;
        dataGrid.ReloadServerData();
    }

    private async Task<GridData<VaccineListDto>> LoadServerData(GridState<VaccineListDto> state)
    {
        var request = new PagedRequest
        {
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = state.SortDefinitions.FirstOrDefault()?.SortBy ?? "Name",
            SortDescending = state.SortDefinitions.FirstOrDefault()?.Descending ?? false,
            SearchTerm = searchString
        };

        var response = await VaccineService.GetAllAsync(request);

        return new GridData<VaccineListDto>
        {
            Items = response.Items,
            TotalItems = response.TotalCount
        };
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<VaccineDialog>("Create Vaccine", options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await VaccineService.CreateAsync((CreateVaccineDto)result.Data);
                Snackbar.Add("Vaccine created successfully", Severity.Success);
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(Guid id)
    {
        var vaccine = await VaccineService.GetByIdAsync(id);
        if (vaccine == null) return;

        var updateDto = new UpdateVaccineDto
        {
            Name = vaccine.Name,
            Manufacturer = vaccine.Manufacturer,
            ApplicationAgeMonths = vaccine.ApplicationAgeMonths,
            Doses = vaccine.Doses,
            DoseIntervalDays = vaccine.DoseIntervalDays,
            RequiresBooster = vaccine.RequiresBooster,
            Notes = vaccine.Notes
        };

        var parameters = new DialogParameters { ["Model"] = updateDto };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = DialogService.Show<VaccineDialog>("Edit Vaccine", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            try
            {
                await VaccineService.UpdateAsync(id, (UpdateVaccineDto)result.Data);
                Snackbar.Add("Vaccine updated successfully", Severity.Success);
                await dataGrid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteVaccine(Guid id)
    {
        try
        {
            await VaccineService.DeleteAsync(id);
            await dataGrid.ReloadServerData();
            Snackbar.Add("Vaccine deleted successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}
